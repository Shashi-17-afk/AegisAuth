# =============================================================================
# AegisAuth — Environment Variables (Phase 1)
# =============================================================================
# Copy this file to `.env` at the repository root and fill in values.
# Never commit real credentials. Never prefix database secrets with NEXT_PUBLIC_.
#
# Where each variable is used:
#   DATABASE_URL, DIRECT_URL  → packages/database (Prisma) + apps/api (via Prisma)
#   API_PORT, WEB_ORIGIN      → apps/api only (server-side)
#   NEXT_PUBLIC_API_URL       → apps/web only (browser-safe API base URL)
#   NODE_ENV                  → all packages
# =============================================================================

# Supabase PostgreSQL — connection pooling URL (runtime / application)
# From Supabase: Project Settings → Database → Connection string → URI (Transaction / Session pooler)
DATABASE_URL=

# Supabase PostgreSQL — direct connection (Prisma migrations)
# From Supabase: Project Settings → Database → Connection string → URI (Direct connection)
DIRECT_URL=

# Fastify API
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# Next.js — public API base URL only (safe to expose to the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

NODE_ENV=development
