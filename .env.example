# =============================================================================
# AegisAuth — Environment Variables
# =============================================================================
# Copy this file to `.env` at the repository root and fill in values.
# Never commit real credentials. Never prefix database secrets with NEXT_PUBLIC_.
#
# Where each variable is used:
#   DATABASE_URL, DIRECT_URL           → packages/database (Prisma)
#   API_PORT, WEB_ORIGIN, WEBAUTHN_*   → apps/api only (server-side)
#   SESSION_TTL_*, RATE_LIMIT_*        → apps/api only
#   NEXT_PUBLIC_API_URL                → apps/web only (browser-safe)
#   NODE_ENV                           → all packages
# =============================================================================

# Supabase PostgreSQL — connection pooling URL (runtime / application)
DATABASE_URL=

# Supabase PostgreSQL — direct connection (Prisma migrations)
DIRECT_URL=

# Fastify API
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# WebAuthn Relying Party
# Production: set RP_ID to your apex domain (e.g. aegisauth.example) and
# ORIGIN to the exact HTTPS origin of the web app (e.g. https://app.aegisauth.example).
WEBAUTHN_RP_NAME=AegisAuth
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Session + challenge TTLs
SESSION_TTL_SECONDS=604800
WEBAUTHN_CHALLENGE_TTL_SECONDS=300

# Auth endpoint rate limit (in-memory; not shared across instances)
RATE_LIMIT_MAX=30
RATE_LIMIT_TIME_WINDOW_MS=60000

# Next.js — browser uses same-origin /api (rewritten to Fastify).
# NEXT_PUBLIC_API_URL is the rewrite upstream target for Next.js config.
NEXT_PUBLIC_API_URL=http://localhost:3001

NODE_ENV=development
