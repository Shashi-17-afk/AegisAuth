    "@aegisauth/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
