// =============================================================================
// AegisAuth — Prisma schema
// =============================================================================
// ID strategy: UUID (@default(uuid())).
// Phase 1: Organization, Application
// Phase 2: PlatformUser identity, passkeys, sessions, challenges, auth events
// Phase 3: Explainable risk assessments (observe mode by default)
// Phase 4: Intent-bound action authorization (passkey confirms server-stored intent)
//
// PlatformUser ≠ future Application end-users. Keep domains separate.
// Passkey private keys NEVER reach AegisAuth — only public credential material.
// Session tokens: store SHA-256 hash only; raw token lives in HttpOnly cookie.
// Challenges: short-lived, single-use, typed (incl. ACTION_AUTHORIZATION).
// Risk records store score/level/reasons — never raw session tokens or public keys.
// Action intents are immutable server-side; WebAuthn does not sign arbitrary JSON.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum WebAuthnChallengeType {
  REGISTRATION
  AUTHENTICATION
  ACTION_AUTHORIZATION
}

enum ActionType {
  DELETE_APPLICATION
  ROTATE_APPLICATION_SECRET
  CHANGE_MEMBER_ROLE
  REMOVE_MEMBER
  EXPORT_SENSITIVE_DATA
}

enum ActionTargetType {
  APPLICATION
  ORGANIZATION_MEMBER
  ORGANIZATION
}

enum ActionAuthorizationStatus {
  PENDING
  AUTHORIZED
  EXECUTED
  EXPIRED
  CANCELLED
  FAILED
}

enum ActionAuthorizationEventType {
  ACTION_AUTHORIZATION_CREATED
  ACTION_AUTHORIZATION_VERIFIED
  ACTION_AUTHORIZATION_EXECUTED
  ACTION_AUTHORIZATION_EXPIRED
  ACTION_AUTHORIZATION_CANCELLED
  ACTION_AUTHORIZATION_FAILED
}

enum AuthenticationEventType {
  PASSKEY_REGISTRATION_SUCCESS
  PASSKEY_REGISTRATION_FAILURE
  PASSKEY_AUTHENTICATION_SUCCESS
  PASSKEY_AUTHENTICATION_FAILURE
  SESSION_CREATED
  SESSION_REVOKED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskDecision {
  ALLOW
  STEP_UP
  DENY
}

enum RiskMode {
  OBSERVE
  ENFORCE
}

enum RiskSignalType {
  UNKNOWN_USER_AGENT
  UNKNOWN_IP
  RECENT_FAILURES
  RAPID_ATTEMPTS
  NEW_CREDENTIAL
  NEW_ACCOUNT
  HIGH_SESSION_COUNT
  LONG_DORMANCY
  COMPOUND_NEW_CONTEXT
  COMPOUND_NEW_CONTEXT_WITH_FAILURES
}

enum RiskSignalSeverity {
  NONE
  LOW
  MEDIUM
  HIGH
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applications         Application[]
  members              OrganizationMember[]
  actionAuthorizations ActionAuthorization[]

  @@map("organizations")
}

model Application {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("applications")
}

/// AegisAuth platform/developer account (dashboard identity).
/// Email is an identifier only — Phase 2 does NOT prove email ownership.
model PlatformUser {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships          OrganizationMember[]
  passkeys             PasskeyCredential[]
  sessions             Session[]
  challenges           WebAuthnChallenge[]
  authenticationEvents AuthenticationEvent[]
  riskAssessments      RiskAssessment[]
  actionAuthorizations ActionAuthorization[]
  actionAuthorizationEvents ActionAuthorizationEvent[]

  @@map("platform_users")
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  platformUserId String           @map("platform_user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platformUserId])
  @@index([platformUserId])
  @@map("organization_members")
}

/// Public WebAuthn credential material only — never private keys.
model PasskeyCredential {
  id             String    @id @default(uuid()) @db.Uuid
  platformUserId String    @map("platform_user_id") @db.Uuid
  /// Base64URL credential ID from the authenticator (unique).
  credentialId   String    @unique @map("credential_id")
  /// COSE public key bytes from SimpleWebAuthn verification.
  publicKey      Bytes     @map("public_key")
  counter        BigInt    @default(0)
  transports     String[]  @default([])
  deviceType     String    @map("device_type")
  backedUp       Boolean   @map("backed_up")
  friendlyName   String?   @map("friendly_name")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastUsedAt     DateTime? @map("last_used_at")

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@map("passkey_credentials")
}

/// Short-lived, single-use WebAuthn challenges. Not stored on PlatformUser permanently.
model WebAuthnChallenge {
  id             String                @id @default(uuid()) @db.Uuid
  challenge      String                @unique
  type           WebAuthnChallengeType
  platformUserId String?               @map("platform_user_id") @db.Uuid
  /// Normalized email for registration/login context when user may not exist yet.
  email          String?
  /// JSON registration context (displayName, organizationName, provisionalUserId, etc.).
  context        Json?
  expiresAt      DateTime              @map("expires_at")
  usedAt         DateTime?             @map("used_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([platformUserId])
  @@index([email])
  @@map("webauthn_challenges")
}

/// Opaque server-side sessions. DB stores token hash only.
model Session {
  id             String    @id @default(uuid()) @db.Uuid
  platformUserId String    @map("platform_user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastUsedAt     DateTime  @default(now()) @map("last_used_at")
  revokedAt      DateTime? @map("revoked_at")
  userAgent      String?   @map("user_agent")
  ipAddress      String?   @map("ip_address")

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Basic auth event log — not a tamper-evident audit chain (future phase).
model AuthenticationEvent {
  id             String                  @id @default(uuid()) @db.Uuid
  platformUserId String?                 @map("platform_user_id") @db.Uuid
  type           AuthenticationEventType
  success        Boolean
  ipAddress      String?                 @map("ip_address")
  userAgent      String?                 @map("user_agent")
  metadata       Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  platformUser    PlatformUser?    @relation(fields: [platformUserId], references: [id], onDelete: SetNull)
  riskAssessments RiskAssessment[]

  @@index([platformUserId])
  @@index([createdAt])
  @@index([type])
  @@map("authentication_events")
}

/// Persist every evaluated signal (triggered and not) for explainability.
/// Avoids opaque score-only records; volume is bounded (~8–10 rows / assessment).
model RiskAssessment {
  id                    String       @id @default(uuid()) @db.Uuid
  platformUserId        String       @map("platform_user_id") @db.Uuid
  authenticationEventId String?      @map("authentication_event_id") @db.Uuid
  score                 Int
  level                 RiskLevel
  recommendedDecision   RiskDecision @map("recommended_decision")
  /// What was actually applied. Phase 3 OBSERVE → always ALLOW for valid WebAuthn.
  enforcedDecision      RiskDecision @map("enforced_decision")
  mode                  RiskMode
  /// Normalized IP used for known-IP comparison (may be null locally).
  ipAddress             String?      @map("ip_address")
  /// Truncated User-Agent (weak contextual signal only).
  userAgent             String?      @map("user_agent") @db.VarChar(512)
  createdAt             DateTime     @default(now()) @map("created_at")

  platformUser         PlatformUser          @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  authenticationEvent  AuthenticationEvent?  @relation(fields: [authenticationEventId], references: [id], onDelete: SetNull)
  signals              RiskSignal[]
  actionAuthorizations ActionAuthorization[]

  @@index([platformUserId])
  @@index([createdAt])
  @@index([level])
  @@index([authenticationEventId])
  @@map("risk_assessments")
}

model RiskSignal {
  id               String             @id @default(uuid()) @db.Uuid
  riskAssessmentId String             @map("risk_assessment_id") @db.Uuid
  type             RiskSignalType
  triggered        Boolean
  contribution     Int
  severity         RiskSignalSeverity
  reason           String
  metadata         Json?
  createdAt        DateTime           @default(now()) @map("created_at")

  riskAssessment RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)

  @@index([riskAssessmentId])
  @@index([type])
  @@map("risk_signals")
}

/// Server-stored immutable action intent + lifecycle for passkey confirmation.
/// Passkey verification authorizes this stored intent via a single-use challenge —
/// it does NOT mean the authenticator signed arbitrary action JSON.
model ActionAuthorization {
  id                  String                    @id @default(uuid()) @db.Uuid
  platformUserId      String                    @map("platform_user_id") @db.Uuid
  organizationId      String                    @map("organization_id") @db.Uuid
  actionType          ActionType                @map("action_type")
  targetType          ActionTargetType          @map("target_type")
  targetId            String                    @map("target_id") @db.Uuid
  /// Canonical intent object (versioned). Immutable after creation.
  intentPayload       Json                      @map("intent_payload")
  /// SHA-256 of canonical serialized intent.
  intentHash          String                    @map("intent_hash") @db.VarChar(64)
  /// Human-readable display fields (names) — not used for security decisions.
  displaySummary      Json                      @map("display_summary")
  status              ActionAuthorizationStatus @default(PENDING)
  riskAssessmentId    String?                   @map("risk_assessment_id") @db.Uuid
  /// When PENDING authorization request expires (before passkey verify).
  pendingExpiresAt    DateTime                  @map("pending_expires_at")
  /// When AUTHORIZED grant must be executed by (set at authorization time).
  executionExpiresAt  DateTime?                 @map("execution_expires_at")
  authorizedAt        DateTime?                 @map("authorized_at")
  executedAt          DateTime?                 @map("executed_at")
  cancelledAt         DateTime?                 @map("cancelled_at")
  failedAt            DateTime?                 @map("failed_at")
  failureReason       String?                   @map("failure_reason")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  platformUser   PlatformUser              @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  riskAssessment RiskAssessment?           @relation(fields: [riskAssessmentId], references: [id], onDelete: SetNull)
  events         ActionAuthorizationEvent[]

  @@index([platformUserId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  @@index([intentHash])
  @@map("action_authorizations")
}

/// Structured lifecycle events — not a tamper-evident chain (later phase).
model ActionAuthorizationEvent {
  id                    String                       @id @default(uuid()) @db.Uuid
  actionAuthorizationId String                       @map("action_authorization_id") @db.Uuid
  platformUserId        String?                      @map("platform_user_id") @db.Uuid
  type                  ActionAuthorizationEventType
  success               Boolean
  ipAddress             String?                      @map("ip_address")
  userAgent             String?                      @map("user_agent")
  metadata              Json?
  createdAt             DateTime                     @default(now()) @map("created_at")

  actionAuthorization ActionAuthorization @relation(fields: [actionAuthorizationId], references: [id], onDelete: Cascade)
  platformUser        PlatformUser?       @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([actionAuthorizationId])
  @@index([platformUserId])
  @@index([createdAt])
  @@index([type])
  @@map("action_authorization_events")
}
